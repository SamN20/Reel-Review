PROJECT_NAME=Reel-Review

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reel-review-db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Ports (Configurable)
FRONTEND_PORT=3000
BACKEND_PORT=8000
DB_VIEWER_PORT=8080
PROXY_PORT=80

# KeyN OAuth Configuration
KEYN_CLIENT_ID=your-keyn-client-id
KEYN_CLIENT_SECRET=your-keyn-client-secret
KEYN_REDIRECT_URI=http://localhost:5173/auth/callback
KEYN_BASE_URL=https://keyn.bynolo.ca

# Nolofication Settings
NOLOFICATION_URL=https://nolofication.bynolo.ca
NOLOFICATION_SITE_ID=vinylvote
NOLOFICATION_API_KEY=your-nolofication-api-key-here

# JWT Auth settings
SECRET_KEY=replace-me-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# TMDB API
TMDB_API_KEY=your-tmdb-api-key

# Contact Details
VITE_SUPPORT_EMAIL=support.reelreview@bynolo.ca
